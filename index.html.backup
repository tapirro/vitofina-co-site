    .crosslink-intro { font-size: 0.9rem; color: #555; margin: 0 0 0.75rem; }
    .crosslink-list { list-style: none; padding: 0; margin: 0; }
    .crosslink-list li { padding: 0.4rem 0; border-bottom: 1px solid #e8e8e8; }
    .crosslink-list li:last-child { border-bottom: none; }
